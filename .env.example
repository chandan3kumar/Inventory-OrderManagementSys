# PostgreSQL Settings (Used by db container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_postgres_password
POSTGRES_DB=inventory_db

# SQLAlchemy DB URL (Used by backend service)
# Note: 'db' refers to the service name in docker-compose.yml
DATABASE_URL=postgresql://postgres:secure_postgres_password@db:5432/inventory_db

# Frontend Settings (Used during frontend Docker build)
# URL of the API gateway (backend container running on port 8000)
VITE_API_URL=http://localhost:8000
